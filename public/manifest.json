{
  "manifest_version": 3,
  "name": "Twitter Likes Manager",
  "version": "1.0.0",

  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],

  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://twitter.com/*/likes",
        "https://x.com/*/likes"
      ],
      "js": ["content.js"]
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}